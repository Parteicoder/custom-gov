<?xml version="1.0" encoding="utf-8"?>
<GameData>
    <BaseGameText>
        <Row Tag="LOC_GOVERNOR_KEQING_NAME">
            <Text>Keqing</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_KEQING_TITLE">
            <Text>Yuheng der Sieben Sterne</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_KEQING_SHORT_TITLE">
            <Text>Yuheng</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_KEQING_DESCRIPTION">
            <Text>Eine entschlossene Gouverneurin, die Liyues Handelsrouten nutzt, um Wachstum, Aufbau und Verwaltung zu beschleunigen.</Text>
        </Row>

        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_BASE_NAME">
            <Text>Magnet des Hafens</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_BASE_DESCRIPTION">
            <Text>Internationale Handelsrouten aus Liyue-Städten haben eine Chance von 35 %, 1 Bevölkerung aus der Zielstadt in die Ursprungsstadt zu ziehen. Zielstädte werden nie unter 1 Bevölkerung reduziert. Wenn Ningguang ebenfalls eingesetzt ist, steigt die Chance auf 50 %.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_1_NAME">
            <Text>Jadeklinge der Verwaltung</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_1_DESCRIPTION">
            <Text>Reichsweit: +2 Gold in allen Städten.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_2_NAME">
            <Text>Yuhengs Planung</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_2_DESCRIPTION">
            <Text>Reichsweit: +15 % Produktion für Bezirke in allen Städten.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_3A_NAME">
            <Text>Schneller Beschluss</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_3A_DESCRIPTION">
            <Text>Reichsweit: +1 Wissenschaft in allen Städten.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_3B_NAME">
            <Text>Ordnung der Qixing</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_KEQING_3B_DESCRIPTION">
            <Text>Reichsweit: +1 Kultur in allen Städten.</Text>
        </Row>

        <Row Tag="LOC_GOVERNOR_NINGGUANG_NAME">
            <Text>Ningguang</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_NINGGUANG_TITLE">
            <Text>Tianquan der Qixing</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_NINGGUANG_SHORT_TITLE">
            <Text>Tianquan</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_NINGGUANG_DESCRIPTION">
            <Text>Politische und wirtschaftliche Macht. Als Tag-Team mit Keqing verstärkt sie den Druck auf fremde Städte, die über Liyues Handelsrouten angebunden sind.</Text>
        </Row>

        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_BASE_NAME">
            <Text>Vertrag der Qixing</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_BASE_DESCRIPTION">
            <Text>Reichsweit: +4 Gold auf Handelsrouten aus eigenen Städten. Tag-Team: Wenn Keqing über eine internationale Handelsroute Bevölkerung abgreift, verliert die Zielstadt zusätzlich 5 Loyalität.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_1_NAME">
            <Text>Wirtschaftlicher Druck</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_1_DESCRIPTION">
            <Text>Reichsweit: +3 Gold aus Handelsrouten mit fremden Städten.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_2_NAME">
            <Text>Politischer Einfluss</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_2_DESCRIPTION">
            <Text>Reichsweit: +2 Einflusspunkte pro Runde auf Stadtstaaten.</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_3_NAME">
            <Text>Handelsnetzwerk der Qixing</Text>
        </Row>
        <Row Tag="LOC_GOVERNOR_PROMOTION_NINGGUANG_3_DESCRIPTION">
            <Text>Reichsweit: +2 Große-Händler-Punkte pro Runde.</Text>
        </Row>
    </BaseGameText>
</GameData>
